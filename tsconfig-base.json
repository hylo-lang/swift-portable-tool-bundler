{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2023",
    "lib": ["es2023"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "build"
  },
  "exclude": ["node_modules", "build", "dist"]
}
